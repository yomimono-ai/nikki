---
---

<header>
	<nav>
		<a href="/" class="brand" aria-label="Yomimono blog home">
			<img src="/logo_full.svg" alt="" aria-hidden="true" width="240" height="40" />
			<span class="word">blog</span>
		</a>
	</nav>
</header>
<style>
	header {
		background: var(--bg);
	}

	nav {
		max-width: 1080px;
		margin: 0 auto;
		padding: 28px 32px 28px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 2px;
		color: var(--ink);
		border-bottom: none;
		padding: 0;
		font-family: var(--serif-display);
		font-size: 28px;
		font-weight: 400;
		letter-spacing: -0.02em;
	}

	.brand {
		transition: color 0.15s ease, filter 0.15s ease;
	}

	.brand:hover {
		color: var(--pink);
		filter: brightness(0.92);
	}

	.brand img {
		display: block;
		width: 240px;
		height: 40px;
		border-radius: 0;
	}

	@media (max-width: 640px) {
		nav {
			padding: 14px 24px;
		}
	}
</style>
