---
---

<header>
	<nav>
		<a href="/" class="brand" aria-label="Yomimono blog home">
			<img src="/logo_full.svg" alt=""
				aria-hidden="true" height="22" />
			<span class="word">blog</span>
		</a>
	</nav>
</header>
<style>
	header {
		background: var(--bg);
	}

	nav {
		max-width: 1080px;
		margin: 0 auto;
		padding: 18px 32px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 2px;
		color: var(--ink);
		border-bottom: none;
		padding: 0;
		font-family: var(--serif-display);
		font-size: 18px;
		font-weight: 400;
		letter-spacing: -0.02em;
	}

	.brand:hover {
		color: var(--pink);
	}

	.brand img {
		display: block;
		height: 22px;
		width: auto;
		border-radius: 0;
	}

	.word {
		position: relative;
		top: 1px;
	}

	@media (max-width: 640px) {
		nav {
			padding: 14px 24px;
		}
	}
</style>
