			"Path=/",
			"Max-Age=" + 60 * 60 * 24 * 365,
			"SameSite=Lax",
		]
		if (
			location.hostname === "yomimono.ai" ||
			location.hostname.endsWith(".yomimono.ai")
		)
			parts.push("Domain=yomimono.ai")
		if (location.protocol === "https:") parts.push("Secure")
		document.cookie = parts.join("; ")
