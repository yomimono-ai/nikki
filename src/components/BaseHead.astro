	window.__initAnonymousAnalytics = function () {
		if (window.posthog && window.posthog.__loaded) return
		posthog.init("phc_s39tnpwtKeA8TBcdM6koDn7Ty8u6yTyFXcxqSZc8fnPw", {
			api_host: "https://eu.i.posthog.com",
			person_profiles: "identified_only",
			persistence: "memory",
			disable_session_recording: true,
		})
	}
	window.__onConsentAccepted = function () {
		if (!window.posthog || !window.posthog.__loaded)
			window.__initAnonymousAnalytics()
		posthog.set_config({ persistence: "localStorage+cookie" })
	}
	// Consent cookie scoped to Domain=yomimono.ai so the marketing site, this
	// blog, and the app share ONE decision — visitors see the banner once.
	window.__readConsent = function () {
		var m = document.cookie.match(/(?:^|; )cookie-consent=([^;]*)/)
		return m ? decodeURIComponent(m[1]) : null
	}
	window.__writeConsent = function (value) {
