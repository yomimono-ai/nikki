---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description } = Astro.props;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#fff7f9" />

<!-- Icons -->
<link rel="icon" type="image/png" sizes="32x32" href="/icon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/icon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/icon-180x180.png" />
<link rel="manifest" href="/manifest.json" />

<!-- Feeds & sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>

<!-- Theme fonts (consumed via CSS variables in src/styles/global.css) -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:wght@400;500;600;700&family=Geist:wght@300;400;500;600&family=Noto+Sans+JP:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
	rel="stylesheet"
/>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Yomimono" />
<meta property="og:url" content={canonicalURL} />
<meta
	property="og:title"
	content="Yomimono — Japanese Reading Practice for Beginners"
/>
<meta
	property="og:description"
	content="Japanese reader tuned to your textbook, your chapter, and the words you actually know — for learners at the N5 and N4 levels."
/>
<meta property="og:image" content="https://yomimono.ai/og-image.png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta
	property="og:image:alt"
	content="Yomimono — Japanese reader tailored to your level."
/>

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta
	name="twitter:title"
	content="Yomimono — Japanese Reading Practice for Beginners"
/>
<meta
	name="twitter:description"
	content="Japanese reader tuned to your textbook, your chapter, and the words you actually know — for learners at the N5 and N4 levels."
/>
<meta name="twitter:image" content="https://yomimono.ai/og-image.png" />
<meta
	name="twitter:image:alt"
	content="Yomimono — Japanese reader tailored to your level."
/>
