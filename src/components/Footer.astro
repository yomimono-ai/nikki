---
const today = new Date();
---

<footer>
	<div class="inner">
		<span>&copy; {today.getFullYear()} Yomimono. All rights reserved.</span>
		<div class="links">
			<a href="https://yomimono.ai">yomimono.ai</a>
			<a href="mailto:hello@yomimono.ai">Contact</a>
		</div>
	</div>
</footer>
<style>
	footer {
		border-top: 1px solid var(--rule);
		height: 100px;
		flex-shrink: 0;
		background: var(--bg);
		color: var(--ink-mute);
		font-size: 14px;
	}

	.inner {
		max-width: 720px;
		height: 100%;
		margin: 0 auto;
		padding: 0 32px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
	}

	.links {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 4px;
	}

	footer a {
		color: inherit;
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: color 0.15s ease, border-color 0.15s ease;
	}

	footer a:hover {
		color: var(--pink);
		border-bottom-color: var(--pink);
	}

</style>
