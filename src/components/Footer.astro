---
const year = new Date().getFullYear();
---

<footer>
	<div class="inner">
		<span class="copyright">&copy; {year} yomimono. All rights reserved.</span>
		<nav class="links">
			<a href="https://yomimono.ai">Yomimono</a>
			<a href="mailto:hello@yomimono.ai">Contact</a>
			<a href="https://yomimono.ai/privacy.html">Privacy</a>
			<a href="https://yomimono.ai/terms.html">Terms</a>
		</nav>
	</div>
</footer>
<style>
	footer {
		border-top: 1px solid var(--rule);
		flex-shrink: 0;
		background: var(--bg);
		color: var(--ink-mute);
		font-size: 14px;
	}

	.inner {
		max-width: 1080px;
		margin: 0 auto;
		padding: 28px 32px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
	}

	.links {
		display: flex;
		gap: 20px;
	}

	footer a {
		color: inherit;
		text-decoration: none;
		border-bottom: none;
		transition: color 0.15s ease;
	}

	footer a:hover {
		color: var(--pink);
	}

	@media (max-width: 640px) {
		.inner {
			flex-direction: column;
			align-items: center;
			text-align: center;
			gap: 12px;
			padding: 24px;
		}
	}
</style>
