---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 720px;
				width: 100%;
				margin: 0 auto;
				padding: 64px 32px;
			}
			.hero {
				text-align: center;
				margin-bottom: 56px;
			}
			.hero .eyebrow {
				font-family: var(--mono);
				font-size: 12px;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: var(--ink-mute);
				margin-bottom: 24px;
			}
			.hero h1 {
				font-family: var(--serif-display);
				font-weight: 600;
				font-size: clamp(36px, 5vw, 64px);
				line-height: 1.05;
				letter-spacing: -0.035em;
				color: var(--ink);
				margin: 0 auto 20px;
				max-width: 14ch;
			}
			.hero h1 em {
				font-style: normal;
				font-weight: 400;
				color: var(--accent-clay);
			}
			.coming-soon {
				text-align: center;
				font-family: var(--serif-display);
				font-weight: 500;
				font-size: 18px;
				color: var(--ink-soft);
				letter-spacing: -0.01em;
				margin: 0;
			}
			.coming-soon em {
				font-style: normal;
				color: var(--accent-clay);
			}
			.hero .sub {
				font-family: var(--serif-body);
				font-size: 18px;
				color: var(--ink-soft);
				max-width: 38ch;
				margin: 0 auto;
				line-height: 1.5;
			}
			ul {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
			}
			li {
				border-bottom: 1px solid var(--rule);
			}
			li:first-child {
				border-top: 1px solid var(--rule);
			}
			li a {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 24px;
				padding: 20px 0;
				border-bottom: none;
				transition: color 0.15s;
			}
			.title {
				margin: 0;
				color: var(--ink);
				font-family: var(--serif-display);
				font-weight: 600;
				font-size: 20px;
				line-height: 1.3;
				letter-spacing: -0.02em;
			}
			.date {
				margin: 0;
				color: var(--ink-mute);
				font-family: var(--mono);
				font-size: 13px;
				letter-spacing: 0.05em;
				white-space: nowrap;
			}
			li a:hover .title,
			li a:hover .date {
				color: var(--pink);
			}
			@media (max-width: 640px) {
				main {
					padding: 40px 24px;
				}
				li a {
					flex-direction: column;
					align-items: flex-start;
					gap: 6px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="eyebrow">Japanese reading practice for beginners</div>
				<h1>Meet Japanese <em>where you are</em></h1>
				<p class="sub">
					Stories tuned to your textbook, your chapter, and the words you actually
					know — for learners at the N5 and N4 levels.
				</p>
			</section>
			{posts.length === 0 && (
				<p class="coming-soon">Posts are <em>coming soon.</em></p>
			)}
			<ul>
				{
					posts.map((post) => (
						<li>
							<a href={`/${post.id}/`}>
								<h4 class="title">{post.data.title}</h4>
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
