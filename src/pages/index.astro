---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import CookieBanner from '../components/CookieBanner.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const [featured, ...rest] = posts;

function excerpt(body = '', limit = 400) {
	const text = body
		.replace(/```[\s\S]*?```/g, '') // fenced code blocks
		.replace(/^#{1,6}\s+.*$/gm, '') // headings
		.replace(/!\[[^\]]*\]\([^)]*\)/g, '') // images
		.replace(/\[([^\]]+)\]\([^)]*\)/g, '$1') // links → text
		.replace(/[*_`>#]/g, '') // leftover markdown syntax
		.replace(/\s+/g, ' ')
		.trim();
	if (text.length <= limit) return text;
	return `${text.slice(0, text.lastIndexOf(' ', limit))}…`;
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 720px;
				width: 100%;
				margin: 0 auto;
				padding: 64px 32px;
			}
			.coming-soon {
				text-align: center;
				font-family: var(--serif-display);
				font-weight: 500;
				font-size: 18px;
				color: var(--ink-soft);
				letter-spacing: -0.01em;
				margin: 0;
			}
			.coming-soon em {
				font-style: normal;
				color: var(--accent-clay);
			}
			.featured {
				display: block;
				padding-bottom: 48px;
				margin-bottom: 8px;
			}
			.featured-image {
				display: block;
				width: 100%;
				height: auto;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				border-radius: 8px;
				margin-bottom: 24px;
			}
			.eyebrow {
				margin: 0 0 12px;
				font-family: var(--mono);
				font-size: 12px;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--pink);
			}
			.featured-title {
				margin: 0;
				color: var(--ink);
				font-family: var(--serif-display);
				font-weight: 600;
				font-size: 34px;
				line-height: 1.15;
				letter-spacing: -0.025em;
				transition: color 0.15s;
			}
			.featured-date {
				margin: 12px 0 0;
				color: var(--ink-mute);
				font-family: var(--mono);
				font-size: 13px;
				letter-spacing: 0.05em;
			}
			.featured-description {
				margin: 16px 0 0;
				color: var(--ink-soft);
				font-size: 17px;
				line-height: 1.6;
			}
			.read-all {
				display: flex;
				justify-content: flex-end;
				align-items: center;
				gap: 6px;
				margin-top: 20px;
				font-family: var(--mono);
				font-size: 13px;
				letter-spacing: 0.05em;
				color: var(--pink);
			}
			.read-all span {
				transition: transform 0.15s;
			}
			.featured:hover .featured-title {
				color: var(--pink);
			}
			.featured:hover .read-all span {
				transform: translateX(4px);
			}
			.eyebrow-section {
				margin: 40px 0 4px;
			}
			.empty-catalog {
				margin: 0;
				padding: 28px 0;			
				font-family: var(--serif-display);
				font-weight: 500;
				font-size: 17px;
				color: var(--ink-soft);
				letter-spacing: -0.01em;
			}
			.empty-catalog em {
				font-style: normal;
				color: var(--accent-clay);
			}
			ul {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
			}
			li {
				border-bottom: 1px solid var(--rule);
			}
			li a {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 24px;
				padding: 18px 0 20px;
				border-bottom: none;
				transition: color 0.15s;
			}
			.title {
				margin: 0;
				color: var(--ink);
				font-family: var(--serif-display);
				font-weight: 600;
				font-size: 20px;
				line-height: 1.3;
				letter-spacing: -0.02em;
			}
			.date {
				margin: 0;
				color: var(--ink-mute);
				font-family: var(--mono);
				font-size: 13px;
				letter-spacing: 0.05em;
				white-space: nowrap;
			}
			li a:hover .title,
			li a:hover .date {
				color: var(--pink);
			}
			@media (max-width: 640px) {
				main {
					padding: 40px 24px;
				}
				li a {
					flex-direction: column;
					align-items: flex-start;
					gap: 6px;
				}
				.featured-title {
					font-size: 27px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{posts.length === 0 && (
				<p class="coming-soon">Posts are <em>coming soon.</em></p>
			)}
			{featured && (
				<a class="featured" href={`/${featured.id}/`}>
					{featured.data.heroImage && (
						<img
							class="featured-image"
							src={featured.data.heroImage.src}
							alt=""
							loading="eager"
						/>
					)}
					<p class="eyebrow">Latest</p>
					<h2 class="featured-title">{featured.data.title}</h2>
					<p class="featured-date">
						<FormattedDate date={featured.data.pubDate} />
					</p>
					<p class="featured-description">{excerpt(featured.body)}</p>
					<span class="read-all">Read post <span aria-hidden="true">→</span></span>
				</a>
			)}
			{featured && (
				<>
					<p class="eyebrow eyebrow-section">Previous</p>
					{rest.length > 0 ? (
						<ul>
							{rest.map((post) => (
							<li>
								<a href={`/${post.id}/`}>
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))}
					</ul>
					) : (
						<p class="empty-catalog">No earlier posts <em>yet.</em></p>
					)}
				</>
			)}
		</main>
		<Footer />
		<CookieBanner />
	</body>
</html>
